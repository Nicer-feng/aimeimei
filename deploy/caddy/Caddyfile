{
	servers {
		protocols h1 h2
	}
}

feng.asia, www.feng.asia {
	root * /var/www/aimeimei

	handle /cat {
		reverse_proxy 127.0.0.1:8000
	}

	# /cat/ 保留原始路径前缀，后端按 /cat/ 路由处理。
	handle /cat/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle /ai {
		rewrite * /
		reverse_proxy 127.0.0.1:8000
	}

	# AI 主应用在 Python 进程里挂载在 /，这里去掉 /ai/ 前缀。
	handle_path /ai/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle /res/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle /favicon.ico {
		reverse_proxy 127.0.0.1:8000
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}

# 兼容旧的直连入口：http://118.31.114.165:8080/
# 后端已经改为只监听 127.0.0.1:8000，由 Caddy 接管公网 8080。
:8080 {
	handle /ai {
		rewrite * /
		reverse_proxy 127.0.0.1:8000
	}

	handle_path /ai/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle {
		reverse_proxy 127.0.0.1:8000
	}
}

# 兼容直接输入 IP 的入口，避免被自动跳到没有可信证书的 https://118.31.114.165/。
http://118.31.114.165 {
	handle /ai {
		rewrite * /
		reverse_proxy 127.0.0.1:8000
	}

	handle_path /ai/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle {
		reverse_proxy 127.0.0.1:8000
	}
}
