[Unit]
Description=AI Platform
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ai-platform
Group=ai-platform
WorkingDirectory=/opt/ai-platform
Environment=AI_PLATFORM_LISTEN=:8080
Environment=AI_PLATFORM_DATA=/opt/ai-platform
ExecStart=/usr/bin/python3 /opt/ai-platform/app.py
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/ai-platform

[Install]
WantedBy=multi-user.target
